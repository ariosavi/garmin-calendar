<settings>
    <setting propertyKey="@Properties.weekStartDay" title="@Strings.WeekStartDayTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.WeekStartSunday</listEntry>
            <listEntry value="1">@Strings.WeekStartMonday</listEntry>
            <listEntry value="2">@Strings.WeekStartSaturday</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.dateFormat" title="@Strings.DateFormatTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.DateFormatISO</listEntry>
            <listEntry value="1">@Strings.DateFormatEuropean</listEntry>
            <listEntry value="2">@Strings.DateFormatUS</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.dateSeparator" title="@Strings.DateSeparatorTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.DateSeparatorSlash</listEntry>
            <listEntry value="1">@Strings.DateSeparatorDash</listEntry>
            <listEntry value="2">@Strings.DateSeparatorDot</listEntry>
            <listEntry value="3">@Strings.DateSeparatorSpace</listEntry>
        </settingConfig>
    </setting>
    <setting propertyKey="@Properties.dateColor" title="@Strings.DateColorTitle">
        <settingConfig type="list">
            <listEntry value="0">@Strings.ColorWhite</listEntry>
            <listEntry value="1">@Strings.ColorRed</listEntry>
            <listEntry value="2">@Strings.ColorBlue</listEntry>
            <listEntry value="3">@Strings.ColorGreen</listEntry>
            <listEntry value="4">@Strings.ColorYellow</listEntry>
            <listEntry value="5">@Strings.ColorOrange</listEntry>
            <listEntry value="6">@Strings.ColorPurple</listEntry>
            <listEntry value="7">@Strings.ColorPink</listEntry>
            <listEntry value="8">@Strings.ColorDkBlue</listEntry>
            <listEntry value="9">@Strings.ColorLtGray</listEntry>
        </settingConfig>
    </setting>
</settings>